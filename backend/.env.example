# Environment variables — copy to .env and fill in values
# DO NOT commit .env to version control

# Application
APP_NAME="Dr. Pooja Agrawal Clinic"
APP_SECRET_KEY=changeme-use-a-long-random-secret
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://clinic_user:clinic_pass@localhost:5432/clinic_db

# Redis (for Celery broker & result backend)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# OAuth2 — Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 — Facebook
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Pricing (USD)
PRICE_15MIN=30
PRICE_30MIN=50

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM="Dr. Pooja Agrawal Clinic <your-email@gmail.com>"

# Doctor profile
DOCTOR_NAME="Dr. Pooja Agrawal"
DOCTOR_EMAIL=pooja@clinic.com
DOCTOR_SPECIALIZATION="General Physician & Consultant"
